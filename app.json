{
  "expo": {
    "name": "RegEntry",
    "slug": "regEntry",
    "scheme": "regentry",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "package": "com.regentry.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true
    },
    "ios": {
      "bundleIdentifier": "com.regentry.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "cameraPermission": "RegEntry needs camera access to capture visitor photos."
        }
      ],
       [
      "expo-location",
        {
          "locationWhenInUsePermission": "RegEntry needs location access to verify you are at the society premises."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1D9E75"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "55ab2c18-8e65-4874-b551-138277adad79"
      }
    }
  }
}
